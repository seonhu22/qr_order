# IDE metadata and editor-specific files.
.idea/
.vscode/
*.iml
.classpath
.project
.settings/

# Java and IDE build outputs. These are recreated locally and should not be committed.
*.class
qrorder/bin/
qrorder/build/
qrorder/out/
qrorder/.gradle/

# Temporary files from older Java tooling.
*.ctxt
.mtj.tmp/

# Packaged artifacts generated during build/release.
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Keep the Gradle wrapper binary under version control.
!qrorder/gradle/wrapper/gradle-wrapper.jar

# JVM crash dumps and runtime logs.
*.log
hs_err_pid*
replay_pid*
logs/
qrorder/logs/

# Frontend dependencies and Vite build cache/output.
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# Built frontend assets copied into the Spring Boot static directory.
qrorder/src/main/resources/static/

# Local-only Spring Boot configuration files with machine/environment secrets.
qrorder/src/main/resources/application-local.properties
qrorder/src/main/resources/application-secret.properties

# OS-specific noise.
.DS_Store

# Local Codex/Claude workspace metadata.
.claude/
CLAUDE.md
